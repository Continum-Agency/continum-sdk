{
  "name": "@continum/sdk",
  "version": "2.0.0",
  "description": "Zero-latency compliance auditing with protect() - one line to secure every LLM call",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "ai",
    "compliance",
    "llm",
    "pii",
    "audit",
    "gdpr",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "security",
    "privacy",
    "protect",
    "zero-latency"
  ],
  "author": "Continum Team",
  "license": "MIT",
  "homepage": "https://continum.co",
  "repository": {
    "type": "git",
    "url": "https://github.com/Continum-Agency/continum-sdk.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Continum-Agency/continum-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.1.3",
    "dotenv": "^16.0.0"
  },
  "peerDependencies": {
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.15.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
